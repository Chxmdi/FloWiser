{
  "name": "@flowiser/backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx --test src/tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrations:run": "node scripts/run-migrations.mjs"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "dependencies": {
    "@flowiser/schemas": "0.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
